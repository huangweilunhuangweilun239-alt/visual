local function makeSpawner()
  local win=Instance.new("Frame", gui)
  win.Name="BaiyanSpawnerWin"; win.Size=UDim2.fromOffset(320,176); win.Position=POS.spawner
  local drag=Instance.new("Frame", win); drag.Size=UDim2.new(1,0,0,44); drag.BackgroundTransparency=1







