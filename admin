local spawnerWin, eventWin, luckyWin, addWin, morphWin

local function newOrToggle(ref, maker, key)
  if not ref or not ref.Parent then
    ref = maker()
    ref.Visible = true
    ensureVisible(ref, key)
    return ref
  end
  ref.Visible = not ref.Visible
  if ref.Visible then ensureVisible(ref, key) end
  return ref
end

