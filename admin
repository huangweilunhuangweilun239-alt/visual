local function pointerInGuiSpace(target)
  local p = UIS:GetMouseLocation()
  local inset = GuiService:GetGuiInset()
  local sg = target:FindFirstAncestorWhichIsA("ScreenGui")
  if sg and sg.IgnoreGuiInset == false then
    return Vector2.new(p.X - inset.X, p.Y - inset.Y)
  else
    return Vector2.new(p.X, p.Y)
  end
end
local function clampToParent(target, absX, absY)
  local parent = target.Parent
  local ox, oy = 0, 0
  if parent and parent.AbsolutePosition then
    local ap = parent.AbsolutePosition
    ox, oy = ap.X, ap.Y
  end
  local pw, ph = parent.AbsoluteSize.X, parent.AbsoluteSize.Y
  local tw, th = target.AbsoluteSize.X, target.AbsoluteSize.Y
  local minX, minY = ox, oy
  local maxX, maxY = ox + pw - tw, oy + ph - th
  local cy = math.clamp(absY, minY, math.max(minY, maxY))
  return UDim2.fromOffset(cx - ox, cy - oy)
  opts = opts or {}
  local DEADZONE = opts.deadzone or 6
  local HOLD_MS  = opts.hold_ms  or 0
  handle.Active, target.Active = true, true
  local dragging, candidate = false, false
  local startTime = 0
  local offsetAbs = Vector2.zero
  local stepConn
  local function stopDrag()
    dragging = false; candidate = false
    if stepConn then stepConn:Disconnect(); stepConn = nil end
    if opts and opts.onRelease then opts.onRelease() end
  end
  handle.InputBegan:Connect(function(input)
    if input.UserInputType ~= Enum.UserInputType.MouseButton1
    and input.UserInputType ~= Enum.UserInputType.Touch then return end
    candidate = true; dragging = false; startTime = os.clock()
    local ptr = pointerInGuiSpace(target)
    offsetAbs = target.AbsolutePosition - ptr
    if stepConn then stepConn:Disconnect() end
    stepConn = RunS.RenderStepped:Connect(function()
      if not candidate then return end
      local now = os.clock()
      local ptrNow = pointerInGuiSpace(target)
      if not dragging then
        local expected = target.AbsolutePosition - offsetAbs
        local dx = math.abs(ptrNow.X - expected.X)
        local dy = math.abs(ptrNow.Y - expected.Y)
        local held = (now - startTime) * 1000 >= HOLD_MS
        if held or dx > DEADZONE or dy > DEADZONE then dragging = true else return end
      end
      local absX = ptrNow.X + offsetAbs.X
      local absY = ptrNow.Y + offsetAbs.Y
      target.Position = clampToParent(target, absX, absY)
    end)
    input.Changed:Connect(function()
      if input.UserInputState == Enum.UserInputState.End
      or input.UserInputState == Enum.UserInputState.Cancel then stopDrag() end
    end)
  end)
  UIS.TouchEnded:Connect(function() stopDrag() end)
end
local function ensureVisible(win, key)
  task.defer(function()
    if not win or not win.Parent then return end
    local p = win.AbsolutePosition
    win.Position = clampToParent(win, p.X, p.Y)
    if key then savePos(key, win) end
  end)
end

