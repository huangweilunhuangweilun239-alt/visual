  -- spawn 1 láº§n (giá»¯ loop cÅ© gá»i láº¡i once() nhÆ° trÆ°á»›c)
local function once()
    local name = (nameBox.Text or ""):match("^%s*(.-)%s*$")
    if name == "" then return end

    local mutation  = normalizeMutationEmpty(mut.Text)    -- "" = Normal
    local traitsStr = T.GetString()                       -- "" | "All" | "A, B, C"

    local okk, res = pcall(function()
        return RF_SpawnBrainrot:InvokeServer(name, mutation, traitsStr)
    end)

    if okk then
        ok2(("SpawnBrainrot [%s | %s | %s]"):format(
            name, mutation ~= "" and mutation or "empty",
            traitsStr ~= "" and traitsStr or "none"
        ))

        -- Äáº·c biá»‡t: spawn kÃ¨m StartEvent tÆ°Æ¡ng á»©ng
        local lname = name:lower()
        if lname == "strawberry elephant" then
            pcall(function() RF_StartEvent:InvokeServer("Strawberry") end)
        elseif lname == "meowl" then
            pcall(function() RF_StartEvent:InvokeServer("Meowl") end)
        end
    else
        er2(tostring(res))
    end
end
  spawn.MouseButton1Click:Connect(once)

  local looping=false; local th
  loop.MouseButton1Click:Connect(function()
    looping=not looping; loop.Text=looping and "Loop: ON" or "Loop: OFF"
    loop.BackgroundColor3=looping and Color3.fromRGB(68,110,82) or Color3.fromRGB(54,62,86)
    if looping then
      if th and coroutine.status(th)~="dead" then return end
      th=coroutine.create(function() while looping do once(); task.wait(0.1) end end)
      coroutine.resume(th)
    end
  end)

  return win
end

