local whitelist = {
    [your user id] = "your user name"
}

local Players = game:GetService("Players")

local function isWhitelisted(player)
    local allowedName = whitelist[player.UserId]
    if not allowedName then
        return false
    end

    return string.lower(player.Name) == string.lower(allowedName)
end

Players.PlayerAdded:Connect(function(player)
    if not isWhitelisted(player) then
        task.wait(1)
        player:Kick("You have been kicked by this experience or its moderators.")
    end
end)
